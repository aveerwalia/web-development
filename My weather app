<html>
    <head>
    <title>
        My Weather Card
    </title>
    <style>
        body {
            background-image:linear-gradient(to bottom, darkblue, purple, coral); 
            background-repeat:no-repeat;
        }

           h1 {
      font-size: 36px;
      color: white;
    }
 
    .text {
      font-size: 18px;
      color: #f0f8ff;
    }
 
    .card {
      width: 400px;
      border: 3px solid white;
      border-radius: 20px;
      background-image: linear-gradient(to bottom right, #1e90ff, #87cefa);
    }
 
    .cloudy {
        color:#f0f8ff;
      font-size: 70px;
      animation: floatCloud 3s infinite alternate;
    }
 
    #temperature {
      font-size: 48px;
      font-weight: bold;
      color: #fffacd;
    }
 
    .info {
      font-size: 18px;
      color: white;
    }
 
    .forecast {
      width: 600px;
      border: 3px solid white;
      border-radius: 15px;
       background-image: radial-gradient(circle, maroon, red);
      color: #003366;
    }
 
    .forecast-title {
      color: #003366;
    }
 
    .day {
      border: 2px solid white;
      font-size: 17px;
      color: #003366;
    }
 
    h2, h3 {
      color: white;
    }
 
    @keyframes floatCloud {
      from {
        transform: translateY(0);
      }
 
      to {
        transform: translateY(20px);
      }
    }
    </style>
    </head>

    <body>
    <h1>
        My Weather App Homepage
    </h1>

    <p class="text">
        Check today's weather to stay ahead of the rain.
    </p>

    <div class="card">
        <h2>
            Today's Weather
        </h2>
    </div>

    <div class="cloudy">
        stormy
    </div>

    <p id="temperature">
        19°C
        Feels like: 15°C
    </p>

    <p class="info">
        City: Sydney<br>
        Suburb: Wentworthville
    </p>

    <p class="info">
        Condition: Heavy Rain and Thunder
    </p>

    <p class="info">
        Humidity: 23%
    </p>

    <p class="info">
        Wind Speed: 16 km/h
    </p>

    
    <h2>
        Weekly Forecast
    </h2>

    <div class="forecast">

        <h3 class="forecast-title">
            Next 7 Days
        </h3>

        <p class="day">Monday(today): Stormy - 8°C-19°C
        </p>

        <p class="day">
        Tuesday: Rainy - 12°C - 21°C
        </p>

        <p class="day">
        Wednesday: Rainy - 13°C - 23°C
        </p>

        <p class="day">
        Thursday: Rainy - 14°C - 23°C
        </p>

        <p class="day">
        Friday: Overcast - 16°C - 24°C
        </p>

        <p class="day">
        Saturday: Sunny - 16°C - 26°C
        </p>
        
        <p class="day">
        Sunday: Sunny - 17°C - 25°C
        </p>
            </div>
    </body>
</html>
